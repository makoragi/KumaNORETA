# Local development only. Values passed via VITE_* are embedded into the built frontend.
# Do not put secrets here unless they are safe to expose in the browser.
VITE_GTFS_RT_TRIP_UPDATES_URL=https://km.bus-vision.jp/realtime/toshibus_trip_update.bin
VITE_GTFS_RT_VEHICLE_POSITIONS_URL=https://km.bus-vision.jp/realtime/toshibus_vpos_update.bin
VITE_GTFS_RT_ALERTS_URL=https://km.bus-vision.jp/realtime/toshibus_alrt_update.bin
VITE_GTFS_RT_USE_MOCK=false
VITE_GTFS_RT_API_KEY=
VITE_GTFS_RT_API_KEY_HEADER=x-api-key
VITE_GTFS_RT_AUTH_TOKEN=
